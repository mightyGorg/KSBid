{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "sourceMap": true,
    "declaration": false,
    "noEmit": false,
    "types": ["node"]
  },
  "include": [
    "prisma.config.ts",
    "src/**/*.ts",
    "src/**/*.d.ts",
    "test/**/*.spec.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
