// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum KsbType {
  KNOWLEDGE
  SKILL
  BEHAVIOR
}

enum EvidenceStatus {
  DRAFT
  SUBMITTED
  APPROVED
  CHANGES_REQUESTED
  REJECTED
}

enum ItemStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum ItemType {
  PHYSICAL
  DIGITAL
}

model User {
  id             String  @id @default(uuid()) @db.Uuid
  email          String  @unique
  name           String
  passwordHash   String
  points         Int     @default(0)
  lifetimePoints Int     @default(0)
  role           Role    @default(USER)
  avatar         String?
  bids           Bid[]
}

model Ksb {
  id          String     @id @default(uuid()) @db.Uuid
  code        String     @unique
  type        KsbType
  description String
  evidence    Evidence[]
}

model Evidence {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  ksbId         String    @db.Uuid
  title         String
  description   String
  feedback      String?
  pointsAwarded Int       @default(0)
  rewarded      Boolean   @default(false)
  submittedAt   DateTime?
  reviewedById  String    @db.Uuid
  ksb           Ksb       @relation(fields: [ksbId], references: [id])
}

model Item {
  id           String     @id @default(uuid()) @db.Uuid
  name         String
  description  String?
  imageUrl     String?
  minimumBid   Int        @default(1)
  closesAt     DateTime
  status       ItemStatus @default(OPEN)
  kind         ItemType   @default(PHYSICAL)
  winningBidId String?    @unique @db.Uuid
  bids         Bid[]      @relation("ItemBids")

  winningBid Bid? @relation("WinningBid", fields: [winningBidId], references: [id])

  @@index([status, closesAt])
  @@map("items")
}

model Bid {
  id       String   @id @default(uuid()) @db.Uuid
  itemId   String   @db.Uuid
  userId   String   @db.Uuid
  amount   Int
  placedAt DateTime @default(now())

  item       Item  @relation("ItemBids", fields: [itemId], references: [id], onDelete: Cascade)
  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  winningFor Item? @relation("WinningBid")

  @@index([itemId, amount, placedAt])
  @@map("bids")
}
