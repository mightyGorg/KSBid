// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum KsbType {
  KNOWLEDGE
  SKILL
  BEHAVIOUR
}

enum EvidenceStatus {
  DRAFT
  SUBMITTED
  APPROVED
  CHANGES_REQUESTED
  REJECTED
}

enum ItemStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum ItemType {
  PHYSICAL
  DIGITAL
}

model User {
  id             String  @id @default(uuid()) @db.Uuid
  email          String  @unique
  name           String
  passwordHash   String
  points         Int     @default(0)
  lifetimePoints Int     @default(0)
  role           Role    @default(USER)
  avatar         String?
}

model Ksb {
  id          String     @id @default(uuid()) @db.Uuid
  code        String     @unique
  type        KsbType
  description String
  evidence    Evidence[]
}

model Evidence {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  ksbId         String    @db.Uuid
  title         String
  description   String
  feedback      String?
  pointsAwarded Int       @default(0)
  rewarded      Boolean   @default(false)
  submittedAt   DateTime?
  reviewedById  String?   @db.Uuid
  ksb           Ksb       @relation(fields: [ksbId], references: [id])
}
